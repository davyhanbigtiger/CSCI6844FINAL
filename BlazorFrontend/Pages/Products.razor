@page "/products"
@inject BlazorFrontend.Services.ApiService Api

<h3>🛒 Products</h3>

@if (products == null)
{
    <p><em>Loading...</em></p>
}
else if (products.Count == 0)
{
    <p class="text-muted">No products found.</p>
}
else
{
    <table class="table table-striped table-bordered mt-3">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in products)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Name</td>
                    <td>@p.Description</td>
                    <td>$@p.Price</td>
                    <td>@p.Stock</td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />
<h5>➕ Add New Product</h5>

<div class="row g-2" style="max-width: 520px">
    <div class="col-12">
        <input class="form-control" placeholder="Name" @bind="newProduct.Name" />
    </div>
    <div class="col-12">
        <input class="form-control" placeholder="Description" @bind="newProduct.Description" />
    </div>
    <div class="col-6">
        <input class="form-control" placeholder="Price" type="number"
               step="0.01" @bind="newProduct.Price" />
    </div>
    <div class="col-6">
        <input class="form-control" placeholder="Stock" type="number"
               @bind="newProduct.Stock" />
    </div>
    <div class="col-12">
        <button class="btn btn-primary" @onclick="HandleAdd">Add Product</button>
        @if (!string.IsNullOrEmpty(message))
        {
            <span class="ms-3 text-success fw-bold">@message</span>
        }
    </div>
</div>

@code {
    private List<BlazorFrontend.Models.ProductDto>? products;
    private BlazorFrontend.Models.ProductDto newProduct = new();
    private string message = "";

    protected override async Task OnInitializedAsync()
        => products = await Api.GetProductsAsync();

    private async Task HandleAdd()
    {
        if (string.IsNullOrWhiteSpace(newProduct.Name)) return;
        await Api.AddProductAsync(newProduct);
        message = "✅ Product added!";
        newProduct = new();
        products = await Api.GetProductsAsync();
    }
}